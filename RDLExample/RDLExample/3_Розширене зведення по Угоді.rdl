    <DataSet Name="Reward">
      <Query>
        <DataSourceName>CRM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FilteredQuoteId">
            <Value>=Parameters!FilteredQuoteId.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SecondQuoteId">
            <Value>=Parameters!SecondQuoteId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>&lt;fetch version="1.0" mapping="logical" distinct="false"&gt;
  &lt;entity name="crms_reward"&gt;
    &lt;attribute name="crms_rewardid" /&gt;
    &lt;attribute name="crms_reward_type" /&gt;
    &lt;attribute name="crms_receiver" /&gt;
    &lt;attribute name="crms_receiver_accountid" /&gt;
    &lt;attribute name="crms_reward_amount_base" /&gt;
    &lt;attribute name="crms_reward_comission_percent" /&gt;
    &lt;attribute name="crms_reward_comission_base" /&gt;
    &lt;attribute name="crms_amount_to_paid_base" /&gt;

    &lt;filter type="and"&gt;
      &lt;condition attribute="statuscode" operator="in"&gt;
        &lt;value&gt;228980002&lt;/value&gt;
        &lt;value&gt;330070003&lt;/value&gt;
        &lt;value&gt;330070004&lt;/value&gt;
      &lt;/condition&gt;
      &lt;condition attribute="crms_reward_type" operator="not-null" /&gt;
    &lt;/filter&gt;

    &lt;link-entity name="quote" from="crms_chainid" to="crms_chainid" alias="q" link-type="inner"&gt;
      &lt;attribute name="quoteid" /&gt;
      &lt;filter type="or"&gt;
        &lt;condition attribute="quoteid" operator="eq" value="@FilteredQuoteId" /&gt;
        &lt;condition attribute="quoteid" operator="eq" value="@SecondQuoteId" /&gt;
      &lt;/filter&gt;
    &lt;/link-entity&gt;

    &lt;order attribute="crms_reward_type" descending="false" /&gt;
  &lt;/entity&gt;
&lt;/fetch&gt;</CommandText>
      </Query>
      <Fields>
        <Field Name="crms_rewardid">
          <DataField>crms_rewardid</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
