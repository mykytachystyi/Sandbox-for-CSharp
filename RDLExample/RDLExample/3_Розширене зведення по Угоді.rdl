                                    <TextRun>
                                      <Value>=FormatNumber(
(
    IIf(
        IsNothing(Sum(Fields!qd_crms_extendedamount_baseValue.Value)),
        0,
        Sum(Fields!qd_crms_extendedamount_baseValue.Value)
    )
    /
    IIf(
        Len(Parameters!SecondQuoteId.Value)=0 
        OR IsNothing(ReportItems!Textbox12.Value),
        1,
        ReportItems!Textbox12.Value
    )
)
-
(
    IIf(
        IsNothing(Sum(Fields!qd_crms_extendedamount_tech_baseValue.Value)),
        0,
        Sum(Fields!qd_crms_extendedamount_tech_baseValue.Value)
    )
    /
    IIf(
        Len(Parameters!SecondQuoteId.Value)=0 
        OR IsNothing(ReportItems!Textbox12.Value),
        1,
        ReportItems!Textbox12.Value
    )
),
2
)</Value>
                                      <Style>
                                        <FontFamily>Arial</FontFamily>
