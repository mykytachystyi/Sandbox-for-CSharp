                                <Paragraph>
                                  <TextRuns>
                                    <TextRun>
                                      <Value>=IIf(
    IsNothing(Sum(Fields!qd_crms_extendedamount_baseValue.Value)) 
    OR Sum(Fields!qd_crms_extendedamount_baseValue.Value) = 0,
    0,
    FormatNumber(
        (
            Sum(Fields!qd_crms_extendedamount_baseValue.Value) -
            Sum(Fields!qd_crms_extendedamount_tech_baseValue.Value)
        )
        /
        Sum(Fields!qd_crms_extendedamount_baseValue.Value) * 100,
        2
    )
)</Value>
                                      <Style>
