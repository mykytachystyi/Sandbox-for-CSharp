  <DataSets>
    <DataSet Name="DataSet">
      <Query>
        <DataSourceName>CRM</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FilteredQuoteId">
            <Value>=Parameters!FilteredQuoteId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>&lt;fetch version="1.0" mapping="logical" distinct="false"&gt;
  &lt;entity name="quote"&gt;
    &lt;attribute name="quoteid" /&gt;
    &lt;attribute name="crms_chainid" /&gt;
    &lt;link-entity name="opportunity" from="opportunityid" to="crms_opportunityid" alias="opp" link-type="inner"&gt;
      &lt;attribute name="opportunityid" /&gt;
      &lt;attribute name="name" alias="OppName" /&gt;
      &lt;attribute name="crms_code" alias="OppCode" /&gt;
    &lt;/link-entity&gt;
    &lt;link-entity name="quotedetail" from="quoteid" to="quoteid" alias="qd" link-type="inner"&gt;
      &lt;attribute name="crms_quantity"/&gt;
      &lt;attribute name="crms_quantity_new"/&gt;
      &lt;attribute name="crms_quantity_renewal"/&gt;
      &lt;attribute name="crms_validity_days" /&gt;
      &lt;attribute name="crms_extendedamount_base" /&gt;
      &lt;attribute name="crms_extendedamount_tech_base" /&gt;
      &lt;link-entity name="product" from="productid" to="productid" alias="prod" link-type="outer"&gt;
        &lt;attribute name="name" /&gt;
      &lt;/link-entity&gt;
      &lt;link-entity name="crms_analytical_article" from="crms_analytical_articleid" to="crms_analytical_articleid" alias="art" link-type="outer"&gt;
        &lt;attribute name="crms_name" /&gt;
      &lt;/link-entity&gt;
    &lt;/link-entity&gt;
    &lt;filter&gt;
      &lt;condition attribute="quoteid" operator="eq" value="@FilteredQuoteId" /&gt;
    &lt;/filter&gt;
  &lt;/entity&gt;
&lt;/fetch&gt;</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
