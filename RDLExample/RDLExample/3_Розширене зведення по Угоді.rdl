    Sum(Fields!qd_crms_extendedamount_tech_baseValue.Value, "DataSet1") /
    IIf(
        Len(Parameters!SecondQuoteId.Value) = 0 
        OR IsNothing(ReportItems!Textbox118.Value) 
        OR ReportItems!Textbox118.Value = 0,
        1,
        ReportItems!Textbox118.Value
    )
),
2)</Value>
